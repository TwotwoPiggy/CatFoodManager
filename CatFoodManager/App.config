<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <connectionStrings>
    <add name="SQLite" connectionString=".\CatFoodManager.db" providerName="System.Data.SqlLite" />
  </connectionStrings>
  <appSettings>
    <!-- 格式: 用分号分隔多个目录路径，目录名会自动作为平台名(如 Taobao, JD, PDD, Douyin) -->
    <add key="PictureFolders" value=""/>
    <!--sample: 使用;分隔多个<add key="regPattern" value="\.([0-9]{2}E[0-9]{2})\.;\.(P[0-9]{2})\."/>-->
  </appSettings>
</configuration>